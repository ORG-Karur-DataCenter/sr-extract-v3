# Copy to .env and fill in
# Comma-separated list of Gemini API keys (from aistudio.google.com)
GEMINI_API_KEYS=key1,key2,key3

# Optional: Claude API key for fallback (from console.anthropic.com)
# Leave empty to use Gemini-only
CLAUDE_API_KEY=

# Optional overrides
GEMINI_MODEL=gemini-1.5-flash
GEMINI_RPM_LIMIT=15
GEMINI_TPM_LIMIT=1000000
MAX_CONCURRENT_WORKERS=4
LOG_LEVEL=INFO
OUTPUT_FORMAT=xlsx
