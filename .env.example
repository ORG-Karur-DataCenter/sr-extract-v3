# Copy to .env and fill in
# Comma-separated list of Gemini API keys (from aistudio.google.com)
GEMINI_API_KEYS=key1,key2,key3

# Optional: Claude API key for fallback (from console.anthropic.com)
# Leave empty to use Gemini-only
CLAUDE_API_KEY=

# Optional overrides (defaults are tuned for gemini-2.5-flash free tier)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RPM_LIMIT=10
GEMINI_TPM_LIMIT=1000000
GEMINI_RPD_LIMIT=500
MAX_CONCURRENT_WORKERS=1
LOG_LEVEL=INFO
OUTPUT_FORMAT=xlsx
