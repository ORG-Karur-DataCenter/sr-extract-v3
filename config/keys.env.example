GEMINI_API_KEY_1=your_gemini_key_here
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# --- FALLBACK MODEL (optional) ---
# Get from: https://console.anthropic.com
CLAUDE_API_KEY=

